# Cyber Intelligence Gateway - Environment Configuration
# Copy this file to .env and configure your values

# Application Settings
APP_NAME=Cyber Intelligence Gateway
DEBUG=false
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_PATH=/data/cig.db

# PCAP Configuration
PCAP_DIR=/data/pcaps
PCAP_ROTATION_SIZE=100M
PCAP_MAX_FILES=100

# Network Interfaces (for PCAP - must match container networking)
LAN_INTERFACE=eth0
WAN_INTERFACE=eth1

# MISP Configuration (optional - leave empty to disable)
MISP_URL=https://misp.example.com
MISP_API_KEY=your-misp-api-key-here
MISP_VERIFY_SSL=false
MISP_UPDATE_INTERVAL=300

# pfBlockerNG Configuration
PFBLOCKER_FEEDS=https://raw.githubusercontent.com/pfBlockerNG/devel/master/etc/rc.d/aliasloader
PFBLOCKER_UPDATE_INTERVAL=3600
PFBLOCKER_LOCAL_BLOCKLIST=/config/pfblocker_local.txt

# DNS Query Logging
DNS_LOG_PATH=/data/logs/dns.log
DNS_QUERY_LOG_ENABLED=true

# Threat Matching
MATCH_DNS_QUERIES=true
MATCH_PCAP_TRAFFIC=true
ALERT_RETENTION_DAYS=30

# Notifications (optional - leave empty to disable)
WEBHOOK_URL=
